# Copy to .env and adjust. All vars are prefixed LENSFY_.

LENSFY_DEBUG=true
# Override the local SQLite location (defaults to ~/.lensfy/lensfy.db)
# LENSFY_DATABASE_URL=sqlite:////absolute/path/to/lensfy.db
# Comma-separated CORS origins for the frontend / Tauri shell
# LENSFY_CORS_ORIGINS=["http://localhost:5173","tauri://localhost"]

# --- Local-only access control ---
# A device token is generated at ~/.lensfy/device_token and required on /api +
# /ws; access is restricted to loopback clients with a loopback Host header.
# No login/password. Defaults are safe for a single-user desktop.
# Turn off all checks (trusted env / debugging only):
# LENSFY_SECURITY_ENABLED=false
# Allow LAN (non-loopback) access — the device token still applies:
# LENSFY_ALLOW_REMOTE=false
# Extra Host-header values to accept (e.g. the machine hostname):
# LENSFY_ALLOWED_HOSTS=["mybox"]

# --- AI assistant (Claude API) ---
# Required to enable the "Assistente IA" view. Without it the feature degrades.
# LENSFY_ANTHROPIC_API_KEY=sk-ant-...
# LENSFY_ANTHROPIC_MODEL=claude-sonnet-4-6
# Set to false to make the agent diagnose-only (no mutating actions at all).
# LENSFY_AI_ALLOW_MUTATIONS=true
