#!/usr/bin/env bash
#
# Lensfy — launcher do app instalado (gerado por install.sh).
#
#   lensfy            inicia (se preciso) e abre no navegador  [ação padrão]
#   lensfy start      inicia em background
#   lensfy stop       para
#   lensfy restart    reinicia
#   lensfy status     estado + health
#   lensfy logs       acompanha o log
#   lensfy open       abre o navegador (inicia se preciso)
#   lensfy update     baixa a última versão do GitHub e atualiza no lugar
#   lensfy version    mostra a versão instalada
#
# Variáveis: LENSFY_HOST (127.0.0.1), LENSFY_PORT (8000), demais LENSFY_* repassadas.
#   LENSFY_REPO   (default https://github.com/fabiocax/lensfy.git) — origem do update
#   LENSFY_BRANCH (default main)
set -euo pipefail

PREFIX="${LENSFY_PREFIX:-${XDG_DATA_HOME:-$HOME/.local/share}/lensfy}"
APP="$PREFIX/app"
VENV="$PREFIX/venv"
STATE="${XDG_STATE_HOME:-$HOME/.local/state}/lensfy"
PID_FILE="$STATE/lensfy.pid"
LOG_FILE="$STATE/lensfy.log"
REF_FILE="$PREFIX/source_ref"
HOST="${LENSFY_HOST:-127.0.0.1}"
PORT="${LENSFY_PORT:-8000}"
URL="http://$HOST:$PORT"
REPO_URL="${LENSFY_REPO:-https://github.com/fabiocax/lensfy.git}"
REPO_BRANCH="${LENSFY_BRANCH:-main}"

is_running() { [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null; }

healthy() { command -v curl >/dev/null 2>&1 && curl -fs "$URL/health" >/dev/null 2>&1; }

wait_health() {
  command -v curl >/dev/null 2>&1 || { sleep 1; return 0; }
  local pid="$1"
  for _ in $(seq 1 40); do
    curl -fs "$URL/health" >/dev/null 2>&1 && return 0
    kill -0 "$pid" 2>/dev/null || return 1
    sleep 0.5
  done
  return 2
}

start() {
  # Servidor já no ar (por este launcher ou por systemd)? nada a fazer.
  if is_running || healthy; then
    echo "Lensfy já está rodando — $URL"
    return 0
  fi
  if [[ ! -x "$VENV/bin/uvicorn" ]]; then
    echo "erro: instalação não encontrada em $PREFIX (rode install.sh)" >&2
    exit 1
  fi
  mkdir -p "$STATE"
  echo "Iniciando Lensfy em $URL …"
  ( cd "$APP" && exec setsid "$VENV/bin/uvicorn" app.main:app \
      --host "$HOST" --port "$PORT" >>"$LOG_FILE" 2>&1 <&- ) &
  local pid=$!
  echo "$pid" > "$PID_FILE"
  case "$(wait_health "$pid"; echo $?)" in
    0) echo "✓ Lensfy no ar: $URL   (log: $LOG_FILE)" ;;
    1) echo "✗ falha ao iniciar — últimas linhas do log:" >&2; tail -n 25 "$LOG_FILE" >&2; rm -f "$PID_FILE"; exit 1 ;;
    *) echo "⚠ iniciou mas /health não respondeu a tempo — veja $LOG_FILE" >&2 ;;
  esac
}

stop() {
  if ! is_running; then echo "Lensfy não está rodando."; rm -f "$PID_FILE"; return 0; fi
  local pid; pid="$(cat "$PID_FILE")"
  echo "Parando Lensfy (PID $pid) …"
  kill -TERM "-$pid" 2>/dev/null || kill -TERM "$pid" 2>/dev/null || true
  for _ in $(seq 1 20); do
    kill -0 "$pid" 2>/dev/null || { rm -f "$PID_FILE"; echo "✓ parado."; return 0; }
    sleep 0.5
  done
  kill -KILL "-$pid" 2>/dev/null || kill -KILL "$pid" 2>/dev/null || true
  rm -f "$PID_FILE"; echo "✓ parado (forçado)."
}

status() {
  if is_running || healthy; then
    echo "● rodando — $URL"
    healthy && echo "  health: ok" || echo "  health: sem resposta"
  else
    echo "○ parado."
  fi
}

open_browser() {
  if command -v xdg-open >/dev/null 2>&1; then xdg-open "$URL" >/dev/null 2>&1 &
  else echo "Abra no navegador: $URL"; fi
}

open_app() {
  healthy || start
  open_browser
}

version() {
  local ref; ref="$(cat "$REF_FILE" 2>/dev/null || echo 'desconhecida')"
  echo "Lensfy — versão instalada: $ref"
}

# Como o servidor está rodando agora: systemd (--service), launcher (PID) ou none.
run_mode() {
  if command -v systemctl >/dev/null 2>&1 && systemctl --user is-active lensfy.service >/dev/null 2>&1; then
    echo systemd
  elif is_running; then
    echo launcher
  else
    echo none
  fi
}

update() {
  local force=0
  [[ "${1:-}" == "--force" || "${1:-}" == "-f" ]] && force=1

  command -v git >/dev/null 2>&1 || { echo "erro: 'git' é necessário para atualizar." >&2; exit 1; }
  if [[ ! -x "$VENV/bin/uvicorn" ]]; then
    echo "erro: instalação não encontrada em $PREFIX (rode install.sh)" >&2; exit 1
  fi

  local tmp; tmp="$(mktemp -d "${TMPDIR:-/tmp}/lensfy-update.XXXXXX")"
  # Valor embutido (aspas duplas) para o trap não referenciar a variável local
  # já fora de escopo no EXIT (quebraria com `set -u`).
  trap "rm -rf '$tmp'" EXIT

  echo "→ Buscando a última versão de $REPO_URL ($REPO_BRANCH) …"
  if ! git clone --depth 1 --branch "$REPO_BRANCH" "$REPO_URL" "$tmp/src" >/dev/null 2>&1; then
    echo "✗ falha ao baixar o repositório — verifique a rede e $REPO_URL" >&2; exit 1
  fi

  local newref oldref
  newref="$(git -C "$tmp/src" rev-parse --short HEAD 2>/dev/null || echo '?')"
  oldref="$(cat "$REF_FILE" 2>/dev/null || echo '')"
  if [[ -n "$oldref" && "$newref" == "$oldref" && $force -eq 0 ]]; then
    echo "✓ Já está na versão mais recente ($newref). Use 'lensfy update --force' para reinstalar."
    return 0
  fi
  [[ -x "$tmp/src/install.sh" ]] || { echo "✗ install.sh ausente no repositório baixado" >&2; exit 1; }

  local mode; mode="$(run_mode)"
  case "$mode" in
    systemd)  echo "→ Parando o serviço para atualizar …"; systemctl --user stop lensfy.service || true ;;
    launcher) echo "→ Parando para atualizar …"; stop || true ;;
  esac

  echo "→ Atualizando ${oldref:-?} → ${newref} (preservando seus dados em ~/.lensfy) …"
  if ! ( cd "$tmp/src" && LENSFY_PREFIX="$PREFIX" bash ./install.sh ); then
    echo "✗ a atualização falhou — a instalação anterior foi mantida." >&2
    # Tenta religar no estado anterior.
    [[ "$mode" == "systemd" ]] && systemctl --user start lensfy.service || true
    [[ "$mode" == "launcher" ]] && start || true
    exit 1
  fi

  case "$mode" in
    systemd)  echo "→ Reiniciando o serviço …"; systemctl --user start lensfy.service || true ;;
    launcher) echo "→ Reiniciando …"; start ;;
    *)        echo "  (servidor não estava rodando; inicie com 'lensfy')" ;;
  esac
  echo "✓ Lensfy atualizado para ${newref}."
}

case "${1:-open}" in
  start)   start ;;
  stop)    stop ;;
  restart) stop; start ;;
  status)  status ;;
  logs)    mkdir -p "$STATE"; exec tail -n 100 -f "$LOG_FILE" ;;
  update)  shift; update "$@" ;;
  version|--version|-v) version ;;
  open|"") open_app ;;
  *) echo "uso: lensfy {start|stop|restart|status|logs|update|version|open}" >&2; exit 2 ;;
esac
